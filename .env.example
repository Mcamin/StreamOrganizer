RADARR_URL=https://radarr.example.com
RADARR_API_KEY=your_radarr_api_key
SONARR_URL=https://sonarr.example.com
SONARR_API_KEY=your_sonarr_api_key

JELLYFIN_URL=https://jellyfin.example.com
JELLYFIN_API_KEY=your_jellyfin_api_key
JELLYFIN_USERNAME=your_jellyfin_username

RADARR_WATCHED_TAG=watched
SONARR_WATCHED_TAG=watched

MOVIE_NEW_ROOT_FOLDER=/movies/New
MOVIE_WATCHED_ROOT_FOLDER=/movies/Watched

SERIES_NEW_ROOT_FOLDER=/series/New
SERIES_WATCHED_ROOT_FOLDER=/series/Watched

LOG_LEVEL=INFO
LOG_FILE=

REQUEST_TIMEOUT=30
MOVE_WAIT_SECONDS=10

# Docker scheduler settings
TZ=Europe/Berlin
CRON_SCHEDULE=0 */6 * * *
RUN_ON_START=false